# Activities.next Environment Configuration
# Copy this file to .env.local for local development
#
# See docs/environment-variables.md for a complete reference.

# ============================================================================
# REQUIRED - Core Configuration
# ============================================================================

# The domain where your instance will be hosted (no protocol, no trailing slash)
# Example: social.example.com
ACTIVITIES_HOST=

# Secret phrase for signing cookies and tokens (generate a random string)
# Generate with: openssl rand -base64 32
ACTIVITIES_SECRET_PHASE=

# ============================================================================
# OPTIONAL - Access Control
# ============================================================================

# Email addresses allowed to register (JSON array)
# If set, only these emails can sign up. Recommended for personal instances.
# ACTIVITIES_ALLOW_EMAILS=["user@example.com"]

# Additional trusted public hosts for canonical URL generation from forwarded headers (JSON array)
# Leave unset unless your reverse proxy legitimately serves this instance on multiple hostnames.
# ACTIVITIES_TRUSTED_HOSTS=["social-alias.example.com"]

# Trust proxy-managed client IP headers for unauthenticated app registration
# throttling. Only enable when your instance is reachable exclusively through a
# proxy that overwrites or strips client-supplied forwarding headers before
# setting its own. Do not enable behind append-only proxies; if the proxy appends
# to X-Forwarded-For, the first element may still be untrusted.
# ACTIVITIES_TRUST_PROXY_IP_HEADERS=false

# ============================================================================
# REQUIRED - Database Configuration
# ============================================================================
# The application requires a database configuration.
# See docs/sqlite-setup.md and docs/postgresql-setup.md for details.

# Option 1: Full JSON configuration
# ACTIVITIES_DATABASE={"type":"sql","client":"better-sqlite3","useNullAsDefault":true,"connection":{"filename":"./dev.sqlite3"}}

# Option 2: Individual environment variables
# ACTIVITIES_DATABASE_CLIENT=better-sqlite3
# ACTIVITIES_DATABASE_SQLITE_FILENAME=./dev.sqlite3

# PostgreSQL individual variables:
# ACTIVITIES_DATABASE_CLIENT=pg
# ACTIVITIES_DATABASE_PG_HOST=localhost
# ACTIVITIES_DATABASE_PG_PORT=5432
# ACTIVITIES_DATABASE_PG_USER=activitynext
# ACTIVITIES_DATABASE_PG_PASSWORD=
# ACTIVITIES_DATABASE_PG_DATABASE=activitynext
# ACTIVITIES_DATABASE_PG_SSL_MODE=disable  # disable, require, verify-ca, verify-full
# ACTIVITIES_DATABASE_PG_POOL_MIN=2
# ACTIVITIES_DATABASE_PG_POOL_MAX=10

# MySQL-compatible individual variables:
# ACTIVITIES_DATABASE_CLIENT=mysql2  # mysql or mysql2
# ACTIVITIES_DATABASE_MYSQL_HOST=localhost
# ACTIVITIES_DATABASE_MYSQL_PORT=3306
# ACTIVITIES_DATABASE_MYSQL_USER=activitynext
# ACTIVITIES_DATABASE_MYSQL_PASSWORD=
# ACTIVITIES_DATABASE_MYSQL_DATABASE=activitynext
# ACTIVITIES_DATABASE_MYSQL_POOL_MIN=2
# ACTIVITIES_DATABASE_MYSQL_POOL_MAX=10

# ============================================================================
# OPTIONAL - Authentication Providers
# ============================================================================

# GitHub OAuth (create an app at https://github.com/settings/developers)
# Callback URL: https://your-domain.tld/api/auth/callback/github
# ACTIVITIES_AUTH_GITHUB_ID=
# ACTIVITIES_AUTH_GITHUB_SECRET=

# ============================================================================
# OPTIONAL - Email Configuration
# ============================================================================
# Required for account verification and email notifications.

# Email provider type: smtp, resend, ses, lambda
# ACTIVITIES_EMAIL_TYPE=smtp
# ACTIVITIES_EMAIL_FROM=noreply@your-domain.tld

# SMTP Configuration
# ACTIVITIES_EMAIL_SMTP_HOST=smtp.example.com
# ACTIVITIES_EMAIL_SMTP_PORT=587
# ACTIVITIES_EMAIL_SMTP_USER=
# ACTIVITIES_EMAIL_SMTP_PASSWORD=
# ACTIVITIES_EMAIL_SMTP_SECURE=false

# Resend Configuration (https://resend.com)
# ACTIVITIES_EMAIL_TYPE=resend
# ACTIVITIES_EMAIL_RESEND_TOKEN=re_xxxxxxxxxxxx

# AWS SES Configuration
# ACTIVITIES_EMAIL_TYPE=ses
# ACTIVITIES_EMAIL_SES_REGION=us-east-1

# AWS Lambda Configuration
# ACTIVITIES_EMAIL_TYPE=lambda
# ACTIVITIES_EMAIL_LAMBDA_REGION=us-east-1
# ACTIVITIES_EMAIL_LAMBDA_FUNCTION_NAME=send-email
# ACTIVITIES_EMAIL_LAMBDA_FUNCTION_QUALIFIER=LIVE

# ============================================================================
# OPTIONAL - Media Storage Configuration
# ============================================================================
# Required for media uploads (images, etc.)
# Without this, media uploads are disabled.

# Storage type: fs (local), s3, object (S3-compatible)
# ACTIVITIES_MEDIA_STORAGE_TYPE=fs

# Local filesystem storage
# ACTIVITIES_MEDIA_STORAGE_PATH=./uploads

# S3 / S3-compatible storage
# ACTIVITIES_MEDIA_STORAGE_BUCKET=my-bucket
# ACTIVITIES_MEDIA_STORAGE_REGION=us-east-1
# ACTIVITIES_MEDIA_STORAGE_HOSTNAME=  # For S3-compatible services (MinIO, DO Spaces, etc.)

# Storage limits
# ACTIVITIES_MEDIA_STORAGE_MAX_FILE_SIZE=209715200        # 200 MiB in bytes
# ACTIVITIES_MEDIA_STORAGE_QUOTA_PER_ACCOUNT=1073741824   # 1 GiB in bytes

# ============================================================================
# OPTIONAL - Fitness File Storage Configuration
# ============================================================================
# Falls back to media storage config if not set separately.

# ACTIVITIES_FITNESS_STORAGE_TYPE=fs
# ACTIVITIES_FITNESS_STORAGE_PATH=./uploads/fitness
# ACTIVITIES_FITNESS_STORAGE_BUCKET=my-fitness-bucket
# ACTIVITIES_FITNESS_STORAGE_REGION=us-east-1
# ACTIVITIES_FITNESS_STORAGE_HOSTNAME=
# ACTIVITIES_FITNESS_STORAGE_PREFIX=fitness/
# ACTIVITIES_FITNESS_STORAGE_MAX_FILE_SIZE=52428800       # 50 MiB in bytes
# ACTIVITIES_FITNESS_STORAGE_QUOTA_PER_ACCOUNT=1073741824 # 1 GiB shared media + fitness quota in bytes
# ACTIVITIES_FITNESS_MAPBOX_ACCESS_TOKEN=
# ACTIVITIES_FITNESS_ROUTE_HEATMAP_MEMORY_BUDGET_BYTES=536870912
# ACTIVITIES_FITNESS_ROUTE_HEATMAP_ACCUMULATION_POINT_LIMIT=160000
# ACTIVITIES_FITNESS_ROUTE_HEATMAP_FILE_POINT_LIMIT=80000

# ============================================================================
# OPTIONAL - Queue Configuration
# ============================================================================
# For background job processing (sending activities, processing uploads).
# Without this, jobs run synchronously (acceptable for small instances).

# Upstash QStash (https://upstash.com/qstash)
# ACTIVITIES_QUEUE_TYPE=qstash
# ACTIVITIES_QUEUE_URL=https://your-domain.tld
# ACTIVITIES_QUEUE_TOKEN=
# ACTIVITIES_QUEUE_CURRENT_SIGNING_KEY=
# ACTIVITIES_QUEUE_NEXT_SIGNING_KEY=

# ============================================================================
# OPTIONAL - Push Notifications
# ============================================================================

# Web Push VAPID keys
# ACTIVITIES_PUSH_VAPID_PUBLIC_KEY=
# ACTIVITIES_PUSH_VAPID_PRIVATE_KEY=
# ACTIVITIES_PUSH_VAPID_EMAIL=mailto:admin@your-domain.tld

# ============================================================================
# OPTIONAL - Observability
# ============================================================================

# OpenTelemetry
# OTEL_SERVICE_NAME=activities.next
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_PROTOCOL=
# OTEL_EXPORTER_OTLP_HEADERS=

# Logging
# LOG_LEVEL=info

# ============================================================================
# Development Only
# ============================================================================

# Node environment
NODE_ENV=development

# Disable Next.js telemetry (set to 1 to disable)
# NEXT_TELEMETRY_DISABLED=1
